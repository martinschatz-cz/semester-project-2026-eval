{"version":3,"kind":"Article","sha256":"b2a3563419e3c45da3e2b9de817ceeb952c3c0a54850280f9c5e7d97548208f1","slug":"icc-info","location":"/evaluation/icc_info.md","dependencies":[],"frontmatter":{"title":"Comprehensive Evaluation of Intraclass Correlation Coefficient (ICC) Results","content_includes_title":false,"github":"https://github.com/UCT-Advanced-Image-Analysis/semester-project-2026-eval","numbering":{"title":{"offset":2}},"exports":[{"format":"md","filename":"icc_info.md","url":"/build/icc_info-8df514772f03a3eb3c2911cd685b1e5b.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The Intraclass Correlation Coefficient (ICC) is a powerful statistical tool to assess the reliability of ratings or measurements. In this context, it quantifies the consistency or agreement among the counts provided by different students for the same images. We typically analyze different types of ICC values depending on the research question.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xc10KePTxl"}],"key":"urXD0y7ihh"},{"type":"heading","depth":2,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Key ICC Types and Their Interpretation:","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"g7jiWpIrwe"}],"identifier":"key-icc-types-and-their-interpretation","label":"Key ICC Types and Their Interpretation:","html_id":"key-icc-types-and-their-interpretation","implicit":true,"key":"pu7lIyf0yh"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":7,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"strong","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"ICC(A,1) - Two-Way Random Effects, Absolute Agreement, Single Rater:","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"BzZVS3LfP7"}],"key":"Hhk5WwuICu"},{"type":"text","value":" This is the most stringent measure of inter-rater reliability. It assesses the extent to which independent ratings from different raters (students) provide exactly the same score for a given target (image). It’s suitable when you want to know if different raters can be used interchangeably.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"NSCFWI59Gv"}],"key":"QCgr1H13yn"}],"key":"ihjjbncBKM"},{"type":"listItem","spread":true,"position":{"start":{"line":9,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"strong","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"ICC(C,1) - Two-Way Random Effects, Consistency, Single Rater:","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"D7l54w9sXM"}],"key":"uFRfcLMSmI"},{"type":"text","value":" This measures consistency rather than absolute agreement. It assesses if raters maintain their relative positions (e.g., if Rater A always scores higher than Rater B by a consistent amount). It doesn’t require the scores to be identical, only that they are consistently proportional or ordered. This is useful when systematic differences between raters are acceptable, but the ranking of targets should be consistent.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"TdgKPXNvqd"}],"key":"DyC9oJkGsu"}],"key":"lZRQyagFsc"},{"type":"listItem","spread":true,"position":{"start":{"line":11,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"strong","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"ICC(A,k) / ICC(C,k) - Reliability of the Average of k Raters:","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"zS5hJDTmYR"}],"key":"iphHl2Erv0"},{"type":"text","value":" These variants estimate the reliability if the final score for each target were an average of ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"snZrl5DDQS"},{"type":"inlineCode","value":"k","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"ZaxrV4SwzZ"},{"type":"text","value":" ratings (where ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"OgIQF3tuTA"},{"type":"inlineCode","value":"k","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"ervUUdZLcR"},{"type":"text","value":" is the number of students). These values are typically higher than single-rater ICCs because averaging tends to reduce random error, thus increasing reliability.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"MtlGA7GkaH"}],"key":"hd3yuZ9Q47"}],"key":"gzlCV0t7m6"}],"key":"RdxX5cMTqa"},{"type":"heading","depth":2,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"General Guidelines for Interpreting ICC Values:","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"ieLdG8BpNo"}],"identifier":"general-guidelines-for-interpreting-icc-values","label":"General Guidelines for Interpreting ICC Values:","html_id":"general-guidelines-for-interpreting-icc-values","implicit":true,"key":"vtQ9bredvj"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":15,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"s